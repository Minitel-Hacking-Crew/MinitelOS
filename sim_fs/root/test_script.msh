# test_script.msh — Tests complets de l'interpreteur .msh

echo ===== 1. ARITHMETIQUE =====
int aa = 10
int bb = 3
int sum = aa+bb
echo sum=10+3 attendu 13 obtenu $sum
int diff = aa-bb
echo diff=10-3 attendu 7 obtenu $diff
int prod = aa*bb
echo prod=10*3 attendu 30 obtenu $prod
int quot = aa/bb
echo quot=10/3 attendu 3 obtenu $quot
int rem = aa%bb
echo rem=10 mod 3 attendu 1 obtenu $rem

echo ===== 2. ARITHMETIQUE AVEC DOLLAR =====
int cnt = 0
cnt=$cnt+5
echo cnt=0+5 attendu 5 obtenu $cnt
cnt=$cnt*2
echo cnt=5*2 attendu 10 obtenu $cnt
cnt=$cnt-3
echo cnt=10-3 attendu 7 obtenu $cnt

echo ===== 3. FLOAT =====
float pi = 3.14
float r = 2.0
float area = pi*r
echo area=3.14*2.0 attendu 6.28 obtenu $area
float half = area/2.0
echo half=6.28/2 attendu 3.14 obtenu $half

echo ===== 4. CONDITIONS ETENDUES =====
int xx = 5
if xx eq 5
echo eq OK
endif
if xx ne 4
echo ne OK
endif
if xx gt 3
echo gt OK
endif
if xx lt 10
echo lt OK
endif
if xx ge 5
echo ge OK
endif
if xx le 5
echo le OK
endif
if xx ge 6
echo ge ERREUR
else
echo ge else OK
endif

echo ===== 5. CONDITIONS STRING =====
string nom = "alice"
if $nom seq alice
echo seq OK
endif
if $nom sne bob
echo sne OK
endif
if $nom seq bob
echo seq ERREUR
else
echo seq else OK
endif

echo ===== 6. FOR AVEC VARIABLES =====
int debut = 1
int fin = 5
int total = 0
for ii debut fin
total=$total+$ii
endfor
echo total=1+2+3+4+5 attendu 15 obtenu $total

echo ===== 7. FOR AVEC DOLLAR =====
int dstart = 3
int dend = 6
int acc = 0
for jj $dstart $dend
acc=$acc+$jj
endfor
echo acc=3+4+5+6 attendu 18 obtenu $acc

echo ===== 8. WHILE AVEC BREAK =====
int ww = 0
while ww lt 20
ww=$ww+1
if ww eq 7
break
endif
endwhile
echo ww attendu 7 obtenu $ww

echo ===== 9. IF ELSE IMBRIQUE =====
int score = 75
if score ge 90
echo excellent
else
if score ge 60
echo bien
else
echo insuffisant
endif
endif

echo ===== 10. AUTO-TYPAGE =====
autoint=42
echo autoint attendu 42 obtenu $autoint
autofloat=1.5
echo autofloat attendu 1.5 obtenu $autofloat
autostr="bonjour monde"
echo autostr attendu bonjour monde obtenu $autostr

echo ===== 11. REDIRECTION =====
echo ligne1 > /root/test_redir.txt
echo ligne2 >> /root/test_redir.txt
cat /root/test_redir.txt

echo ===== 12. EXIT =====
echo avant exit
exit
echo ERREUR ceci ne doit pas apparaitre
